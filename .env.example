APP_ENV=local
API_HOST=127.0.0.1
API_PORT=9520
FRONTEND_PORT=9521

# 推荐使用 PostgreSQL；先执行 infra/docker-compose.yml 启动本地数据库。
DATABASE_URL=postgresql+psycopg://rag_user:rag_password@localhost:5432/rag_platform
# 只想快速单机跑通时，可以临时改回 SQLite。
# DATABASE_URL=sqlite:///./storage/dev.db

# 示例密钥只用于本地开发，不要把真实密钥提交到仓库。
JWT_SECRET_KEY=change-me-in-local-env
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
LOCAL_STORAGE_ROOT=storage/uploads

SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=replace-with-local-smtp-authorization-code
SMTP_FROM_EMAIL=your-email@qq.com
SMTP_FROM_NAME=企业知识平台
SMTP_USE_SSL=true
SMTP_USE_TLS=false
EMAIL_CODE_EXPIRE_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60

LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=replace-with-local-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
RAG_TOP_K=5
RETRIEVAL_MODE=hybrid
RETRIEVAL_CANDIDATE_LIMIT=30
RETRIEVAL_SCORE_THRESHOLD=0
VECTOR_INDEX_ENABLED=true
VISION_MODEL=qwen3-vl:8b
EMBEDDING_MODEL=bge-m3:567m
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://127.0.0.1:11434
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=60
RERANK_ENABLED=true
RERANK_MODEL_PATH=L:\RAG_系统\models

N8N_URL=http://localhost:5678
N8N_USERNAME=replace-with-local-username
N8N_PASSWORD=replace-with-local-password

MINIO_ENDPOINT=http://localhost:9000
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_ACCESS_KEY=replace-with-local-access-key
MINIO_SECRET_KEY=replace-with-local-secret-key
MINIO_BUCKET=enterprise-knowledge-platform
MINIO_SECURE=false

NEO4J_URI=bolt://localhost:7687
NEO4J_ENABLED=false
NEO4J_USERNAME=replace-with-local-username
NEO4J_PASSWORD=replace-with-local-password
NEO4J_DATABASE=neo4j

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=replace-with-local-username
MYSQL_PASSWORD=replace-with-local-password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CELERY_ENABLED=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

MILVUS_HOST=localhost
MILVUS_GRPC_PORT=19530
MILVUS_HTTP_PORT=9091
MILVUS_ALIAS=default
MILVUS_COLLECTION=rag_document_chunks
MILVUS_METRIC_TYPE=COSINE
# 单机开发或资源受限服务器可使用 Milvus Lite，例如 storage/milvus.db；留空则连接独立 Milvus。
MILVUS_URI=
VECTOR_TIMEOUT_SECONDS=10
ATTU_URL=http://localhost:3000
ETCD_ENDPOINT=http://localhost:2379

RELATIONAL_DB=postgresql
VECTOR_STORE=milvus
GRAPH_DB=neo4j
FILE_STORAGE=minio
AUTO_CREATE_SCHEMA=true
METRICS_ENABLED=true

WORKSPACE_ISOLATION=true
ALLOW_WORKSPACE_SYNC=false
ALLOW_WORKSPACE_COPY=false
ALLOW_CROSS_WORKSPACE_IMPORT=false

VITE_API_BASE_URL=http://127.0.0.1:9520
